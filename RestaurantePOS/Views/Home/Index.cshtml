@{
    Layout = null;
    ViewData["Title"] = "Login POS";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Prime Steakhouse</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style>
        body { background-color: #121212; color: #ffffff; }
    </style>
</head>
<body class="h-screen w-screen flex items-center justify-center bg-gray-900 text-white">

    <div class="w-full max-w-sm bg-gray-800 rounded-3xl p-8 shadow-2xl flex flex-col items-center">
        <!-- Header -->
        <h1 class="text-2xl font-bold mb-2 tracking-wide">Prime Steakhouse</h1>
        <p class="text-gray-400 mb-6 text-sm">Ingresa tu código de acceso al sistema</p>

        @if (TempData["Error"] != null)
        {
            <div class="bg-red-500/20 text-red-400 p-3 rounded-lg w-full text-center text-sm mb-4 border border-red-500/50">
                @TempData["Error"]
            </div>
        }

        <!-- PIN Display Input form -->
        <form asp-controller="Home" asp-action="Login" method="post" id="loginForm" class="w-full">
            <input type="password" id="pinInput" name="pin" readonly
                   class="w-full bg-gray-900 border border-gray-700 text-center text-3xl tracking-[1em] rounded-xl py-4 pt-4 pb-4 mb-8 text-white focus:outline-none"
                   placeholder="****" />

            <!-- Numpad -->
            <div class="grid grid-cols-3 gap-4 w-full">
                @for (int i = 1; i <= 9; i++)
                {
                    <button type="button" onclick="appendPin(@i)" 
                            class="bg-gray-700 hover:bg-gray-600 active:bg-gray-500 text-2xl font-semibold py-4 rounded-full transition-colors">
                        @i
                    </button>
                }

                <!-- Clear Button -->
                <button type="button" onclick="clearPin()" 
                        class="bg-red-900/50 hover:bg-red-800/50 text-red-400 text-xl font-semibold py-4 rounded-full transition-colors flex justify-center items-center">
                    <span class="material-symbols-outlined">backspace</span>
                </button>

                <!-- 0 -->
                <button type="button" onclick="appendPin(0)" 
                        class="bg-gray-700 hover:bg-gray-600 active:bg-gray-500 text-2xl font-semibold py-4 rounded-full transition-colors">
                    0
                </button>

                <!-- Enter Button -->
                <button type="submit" 
                        class="bg-green-600 hover:bg-green-500 text-white text-xl font-semibold py-4 rounded-full transition-colors flex justify-center items-center">
                    <span class="material-symbols-outlined">login</span>
                </button>
            </div>
        </form>
    </div>

    <script>
        const maxPinLength = 4; // Ajusta según tu necesidad

        function appendPin(number) {
            const input = document.getElementById('pinInput');
            if (input.value.length < maxPinLength) {
                input.value += number;
            }
        }

        function clearPin() {
            const input = document.getElementById('pinInput');
            input.value = input.value.slice(0, -1);
        }
    </script>
</body>
</html>
